<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Responsive Portfolio</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="style.css">

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
<div class="container">

<a class="navbar-brand" href="#">Yuga Portfolio</a>

<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
<span class="navbar-toggler-icon"></span>
</button>

<div class="collapse navbar-collapse" id="menu">

<ul class="navbar-nav ms-auto">

<li class="nav-item">
<a class="nav-link" href="#home">Home</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#about">About</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#projects">Projects</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#contact">Contact</a>
</li>

</ul>

</div>

</div>
</nav>

<section id="home" class="hero">

<h1>Welcome To My Portfolio</h1>

<p>Full Stack Development Intern</p>

<a href="#projects" class="btn btn-primary">
View Projects
</a>

</section>

<section id="about" class="container py-5">

<h2 class="text-center mb-4">About Me</h2>

<p class="text-center">
Passionate learner exploring HTML, CSS, JavaScript and Full Stack Development.
</p>

</section>

<section id="projects" class="container py-5">

<h2 class="text-center mb-5">Projects</h2>

<div class="row">

<div class="col-md-4">

<div class="card card-hover">

<div class="card-body">

<h5>Task 1</h5>

<p>Registration Form</p>

</div>

</div>

</div>

<div class="col-md-4">

<div class="card card-hover">

<div class="card-body">

<h5>Task 2</h5>

<p>Multi Step Form</p>

</div>

</div>

</div>

<div class="col-md-4">

<div class="card card-hover">

<div class="card-body">

<h5>Task 3</h5>

<p>Responsive Portfolio</p>

</div>

</div>

</div>

</div>

</section>

<section id="contact" class="container py-5">

<h2 class="text-center mb-4">Contact</h2>

<form>

<input class="form-control mb-3" placeholder="Name">

<input class="form-control mb-3" placeholder="Email">

<textarea class="form-control mb-3" rows="4" placeholder="Message"></textarea>

<button class="btn btn-success">
Send Message
</button>

</form>

</section>

<footer>

<p>
© 2026 Yuga Portfolio
</p>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
